{
  "env": {
    "TRACE_TO_LANGFUSE": "true",
    "CC_LANGFUSE_CONFIG_FILE": "/home/hiroki/.claude/langfuse_hook_config.json",
    "CC_LANGFUSE_DEBUG": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(gws:*)",
      "Bash(rbw get:*)",
      "Bash(cargo check:*)",
      "Bash(pkg-config --version)",
      "Bash(dpkg -l *)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(set:*)",
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(*.pem)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [
      {
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {},
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "network": {
      "allowAllUnixSockets": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.cache",
        "/home/hiroki/.local/share/rbw",
        "/run/user/1000",
        "/tmp"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "externalEditor": "zed",
  "effortLevel": "medium"
}
