{
  "permissions": {
    "allow": [
      "WebFetch(domain:v2.tauri.app)",
      "Bash(ls:*)",
      "Bash(gws:*)",
      "Bash(npm install:*)",
      "Bash(cargo check:*)",
      "Bash(pkg-config --version)",
      "Bash(dpkg -l libssl-dev)",
      "Bash(dpkg -l libgtk-3-dev)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(set:*)",
      "Bash(rbw list:*)",
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)"
    ]
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "~/.cache",
        "/home/hiroki/.local/share/rbw",
        "/run/user/1000",
        "/tmp/build"
      ]
    }
  }
}
